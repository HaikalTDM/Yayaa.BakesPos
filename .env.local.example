# ============================================================
# Yayaa.Bakes — Supabase Configuration
# ============================================================
# 1. Run schema.sql in your Supabase SQL Editor
# 2. Copy the STORE_ID it prints at the end
# 3. Paste it below as NEXT_PUBLIC_STORE_ID
# 4. Copy your project URL and anon key from Supabase Dashboard
#    → Settings → API → Project URL / anon public key
# ============================================================

# Supabase project URL (required for non-mock mode)
# Example: https://abc123xyz.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon / public key (NOT the service_role secret)
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your store ID (printed after running schema.sql)
# Leave as default to run in mock/offline mode
NEXT_PUBLIC_STORE_ID=00000000-0000-0000-0000-000000000001
